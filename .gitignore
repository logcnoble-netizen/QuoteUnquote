# Dependencies
node_modules/

# Secrets — never commit real credentials
.env
.env.*
!.env.example

# Runtime data (mutable order/idempotency store). Seed data is tracked.
data/orders.json
data/idempotency.json

# Generated per-order files (customer avatars + composited prints). Transient —
# recreated at runtime, uploaded to Printify, and pruned by src/cleanup.js.
data/uploads/
data/prints/

# Logs & OS cruft
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# Editor / local tooling
.vscode/
.idea/
.claude/

# Print fonts (assets/fonts/Inter-*.ttf) are intentionally committed so Railway
# renders prints in the same Inter the site preview shows (SIL OFL licensed).
