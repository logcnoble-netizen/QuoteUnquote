# =============================================================================
# QuoteUnquote — Environment Configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# On Railway, set these in the project's "Variables" tab instead of a file.
# =============================================================================

# --- Runtime ----------------------------------------------------------------
# Railway injects PORT automatically. Locally, defaults to 3000 if unset.
PORT=3000
# Public origin of the deployed site. Used for CAPI event_source_url,
# Printify external references, and Stripe redirect fallbacks.
PUBLIC_URL=http://localhost:3000
NODE_ENV=development
# Retention window (hours) before generated avatars/print previews in data/ are
# swept. Kept long enough for admin verification. Default 168 (7 days).
CLEANUP_TTL_HOURS=168

# --- Stripe (REQUIRED for checkout) -----------------------------------------
# Secret key stays server-side ONLY. Never ship it in the client bundle.
STRIPE_SECRET_KEY=sk_test_<REPLACE_ME>
# Publishable key is safe to expose to the browser (served via GET /api/config).
STRIPE_PUBLISHABLE_KEY=pk_test_<REPLACE_ME>
# Webhook signing secret from `stripe listen` or the Dashboard endpoint.
STRIPE_WEBHOOK_SECRET=whsec_<REPLACE_ME>

# --- Printify (REQUIRED for print-on-demand fulfillment) --------------------
# Personal Access Token from https://printify.com/app/account/api
PRINTIFY_API_TOKEN=<REPLACE_ME>
# Numeric shop id from GET /v1/shops.json
SHOP_ID=00000000
# Print provider id. Default printer is "Ink Blot Merch". Look up the id for
# your chosen blueprint via GET /v1/catalog/blueprints/{id}/print_providers.json
PRINTIFY_PRINT_PROVIDER_ID=0
# Blueprint id for the Shaka Wear Max Heavyweight blank you print on.
PRINTIFY_BLUEPRINT_ID=0

# --- Meta Conversions API (OPTIONAL — server-side ad attribution) -----------
META_PIXEL_ID=
META_CAPI_TOKEN=
# Optional: Test Event Code from Events Manager while validating.
META_TEST_EVENT_CODE=

# --- TikTok Events API (OPTIONAL — server-side ad attribution) --------------
TIKTOK_PIXEL_ID=
TIKTOK_CAPI_TOKEN=

# --- Admin verification + alerting ------------------------------------------
# REQUIRED to use the admin verification API (GET /api/admin/pending). Long
# random string. If unset, the admin routes return 503 (disabled by default).
ADMIN_TOKEN=
# Discord incoming webhook URL. If set, print/quarantine failures ping here.
DISCORD_WEBHOOK_URL=
# Where operational alerts should be addressed (shown in the alert body).
ADMIN_EMAIL=ops@quoteunquote.example
